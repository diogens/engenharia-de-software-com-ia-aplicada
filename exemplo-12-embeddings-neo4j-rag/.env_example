# OpenRouter Configurations
OPENROUTER_API_KEY="key 123"
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME="RAG example"

# Models
NLP_MODEL="google/gemma-3-27b-it:free"

# Embeddings (usings Transforms.js locally)
EMBEDDING_MODEL="Xenova/all-MiniLM-L6-v2"

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_URI=bolt://localhost:7687
NEO4J_DATABASE=neo4j

# Vector search threshold
NEO4J_VECTOR_THRESHOLD=0.9
